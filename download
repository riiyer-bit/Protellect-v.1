    st.markdown("##### 📡 GPCR Association")
    gpcr = UniProtClient.extract_gpcr_info(pdata)

    if gpcr["is_gpcr"]:
        coupling_str = ", ".join(gpcr["coupling"]) if gpcr["coupling"] else "Unknown"
        st.markdown(
            f"<div style='background:#0a2a4a;border:2px solid #00d4ff;border-radius:10px;"
            f"padding:1rem 1.5rem;'>"
            f"<div style='display:flex;align-items:center;gap:12px;'>"
            f"<span style='font-size:2rem;'>📡</span>"
            f"<div>"
            f"<p style='color:#00d4ff;font-weight:700;font-size:1rem;margin:0;'>GPCR — Important / Piggybacked</p>"
            f"<p style='color:#c9d8e8;margin:4px 0 0;font-size:0.88rem;'>"
            f"Class: <b>{gpcr.get('class','—')}</b> · G-protein coupling: <b>{coupling_str}</b></p>"
            f"</div></div></div>",
            unsafe_allow_html=True,
        )
        # Therapeutic implications
        st.markdown("""
        <div class='card' style='margin-top:0.8rem;'>
          <h4>Therapeutic Relevance</h4>
          <p>GPCRs are the most druggable protein class (~34% of FDA-approved drugs target GPCRs).
          This protein's GPCR nature makes it a prime therapeutic target.
          Consider: biased agonism, allosteric modulation, and antibody-based approaches.</p>
        </div>
        """, unsafe_allow_html=True)
    else:
        st.markdown(
            "<div style='background:#0a1929;border:1px solid #1e3a5f;border-radius:8px;"
            "padding:0.8rem 1.2rem;color:#5a7a9a;font-size:0.88rem;'>"
            "Not classified as a GPCR in UniProt.</div>",
            unsafe_allow_html=True,
        )

    # Interaction partners
    _render_interactions(pdata)


def _render_interactions(pdata: dict):
    interactions = []
    for c in pdata.get("comments", []):
        if c.get("commentType") == "INTERACTION":
            for inter in c.get("interactions", []):
                p2 = inter.get("interactantTwo", {})
                gene2 = p2.get("geneName", p2.get("uniProtKBAccession","?"))
                interactions.append(gene2)
    if interactions:
        st.markdown(f"**Known interactors:** " + " · ".join(f"`{i}`" for i in interactions[:12]))


# ─── Disease classification: somatic vs germline ───────────────────────────────
def _render_disease_classification(pdata: dict, clinvar_data: dict | None):
    st.markdown("##### 🧬 Disease Classification — Somatic vs Germline")

    diseases = UniProtClient.extract_diseases(pdata)
    variants = (clinvar_data or {}).get("variants", [])

    # From ClinVar origin field
    somatic_conditions  = set()
    germline_conditions = set()
    for v in variants:
        origin = v.get("origin", "").lower()
        cond   = v.get("condition", "")
        if not cond or cond == "Not specified":
            continue
        if "somatic" in origin:
            somatic_conditions.add(cond)
        elif "germline" in origin or "inherited" in origin or "de novo" in origin:
            germline_conditions.add(cond)
        else:
            # Infer from ClinVar sig
            sig = v.get("clinical_significance","").lower()
            if "somatic" in sig:
                somatic_conditions.add(cond)
            elif v.get("path_score",0) >= 4:
                germline_conditions.add(cond)

    col_g, col_s = st.columns(2)

    with col_g:
        st.markdown(
            f"<div style='background:#0a2a1a;border:1px solid #00c896;border-radius:10px;"
            f"padding:1rem;margin-bottom:0.5rem;'>"
            f"<p style='color:#00c896;font-weight:700;font-size:1rem;margin:0 0 0.5rem;'>"
            f"🧬 Germline ({len(germline_conditions)})</p>"
            f"<p style='color:#8ab4d4;font-size:0.78rem;margin:0 0 0.5rem;'>"
            f"Heritable — present in all cells from birth</p>",
            unsafe_allow_html=True,
        )
        if germline_conditions:
            for c in sorted(germline_conditions)[:10]:
                st.markdown(
                    f"<div style='color:#b2e4d0;font-size:0.82rem;margin:3px 0;'>◆ {c[:70]}</div>",
                    unsafe_allow_html=True,
                )
        else:
            st.markdown("<p style='color:#5a7a9a;font-size:0.82rem;'>No germline classifications found.</p>",
                        unsafe_allow_html=True)
        st.markdown("</div>", unsafe_allow_html=True)

    with col_s:
        st.markdown(
            f"<div style='background:#2a0a1a;border:1px solid #ff2d55;border-radius:10px;"
            f"padding:1rem;margin-bottom:0.5rem;'>"
            f"<p style='color:#ff2d55;font-weight:700;font-size:1rem;margin:0 0 0.5rem;'>"
            f"🔴 Somatic ({len(somatic_conditions)})</p>"
            f"<p style='color:#8ab4d4;font-size:0.78rem;margin:0 0 0.5rem;'>"
            f"Acquired — arises in specific cell populations</p>",
            unsafe_allow_html=True,
        )
        if somatic_conditions:
            for c in sorted(somatic_conditions)[:10]:
                st.markdown(
                    f"<div style='color:#ffb3c6;font-size:0.82rem;margin:3px 0;'>◆ {c[:70]}</div>",
                    unsafe_allow_html=True,
                )
        else:
            st.markdown("<p style='color:#5a7a9a;font-size:0.82rem;'>No somatic classifications found.</p>",
                        unsafe_allow_html=True)
        st.markdown("</div>", unsafe_allow_html=True)

    # UniProt disease cards
    if diseases:
        st.markdown("**UniProt Disease Annotations**")
        for d in diseases[:8]:
            note = d.get("note","")
            omim = d.get("omim","")
            omim_link = f" · [OMIM {omim}](https://www.omim.org/entry/{omim})" if omim else ""
            st.markdown(
                f"<div class='card'>"
                f"<h4>{d['name']}{omim_link}</h4>"
                f"<p>{d.get('desc','')[:300]}</p>"
                f"{'<p style=\"color:#ffd60a;font-size:0.8rem;\">' + note[:200] + '</p>' if note else ''}"
                f"</div>",
                unsafe_allow_html=True,
            )
